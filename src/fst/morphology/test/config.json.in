{
    "analyser": "@abs_builddir@/../../analyser-gt-desc.hfstol",
    "generator": "@abs_builddir@/../../generator-gt-desc.hfstol",
    "nouns": {
        "lexcfile": "@abs_srcdir@/../stems/nouns.lexc",
        "lemmatags": ["+N+Sg+Nom", "+N+Pl+Nom"]
    },
    "adjectives": {
        "lexcfile": "@abs_srcdir@/../stems/adjectives.lexc",
        "lemmatags": ["+A+Sg+Nom", "+A+Sg+Gen"]
    },
    "propernouns": {
        "lexcfile": "@abs_srcdir@/../stems/propernouns.lexc",
        "lemmatags": ["+N+Prop+Sg+Nom", "+N+Prop+Pl+Nom"],
        "exclusions": ["ProperNounsGeo"]
    },
    "verbs": {
        "lexcfile": "@abs_srcdir@/../stems/verbs.lexc",
        "lemmatags": ["+V+Pers+Sup+Ill"],
        "exclusiosns": ["\\+Pref"]
    }
}
